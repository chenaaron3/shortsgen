{
  "$ref": "#/definitions/VideoManifest",
  "definitions": {
    "VideoManifest": {
      "type": "object",
      "properties": {
        "cacheKey": {
          "type": "string"
        },
        "fps": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "durationInFrames": {
          "type": "number"
        },
        "scenes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "imagePath": {
                "type": "string"
              },
              "voicePath": {
                "type": "string"
              },
              "durationInSeconds": {
                "type": "number"
              },
              "imageWidth": {
                "type": "number"
              },
              "imageHeight": {
                "type": "number"
              }
            },
            "required": [
              "text",
              "imagePath",
              "voicePath",
              "durationInSeconds"
            ],
            "additionalProperties": false
          }
        },
        "captions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "startMs": {
                "type": "number"
              },
              "endMs": {
                "type": "number"
              },
              "timestampMs": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "confidence": {
                "type": [
                  "number",
                  "null"
                ]
              }
            },
            "required": [
              "text",
              "startMs",
              "endMs",
              "timestampMs",
              "confidence"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "cacheKey",
        "fps",
        "width",
        "height",
        "durationInFrames",
        "scenes",
        "captions"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}